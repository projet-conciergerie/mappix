{% extends 'base.html.twig' %}

{% block title %}Inscription - Mappix{% endblock %}

{% block body %}

<main class="flex-1 flex items-center justify-center">

<!-- <div class="min-h-screen flex items-center justify-center bg-gray-800"> -->

    <div class="w-full max-w-md my-6">

        <!-- Logo + Titre -->
        <div class="text-center mb-10 flex flex-col items-center">
            <img src="{{ asset('images/logo1.png') }}" alt="Mappix" class="w-48">
            <h1 class="text-2xl text-white font-semibold mt-4">
                Créer un compte
            </h1>
        </div>

        {{ form_start(registrationForm) }}

        <!-- Messages d'erreur globaux -->
        {% if form_errors(registrationForm) %}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-5">
            {{ form_errors(registrationForm) }}
        </div>
        {% endif %}

        <!-- Nom -->
        <div class="mb-5">
            {{ form_widget(registrationForm.nom, {
            attr: {
            class: 'w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3 focus:outline-none
            focus:ring-2 focus:ring-white focus:border-white transition',
            placeholder: 'Nom'
            }
            }) }}
            {{ form_errors(registrationForm.nom) }}
        </div>

        <!-- Prénom -->
        <div class="mb-5">
            {{ form_widget(registrationForm.prenom, {
            attr: {
            class: 'w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3 focus:outline-none
            focus:ring-2 focus:ring-white focus:border-white transition',
            placeholder: 'Prénom'
            }
            }) }}
            {{ form_errors(registrationForm.prenom) }}
        </div>

        <!-- Pseudo -->
        <div class="mb-5">
            {{ form_widget(registrationForm.pseudo, {
            attr: {
            class: 'w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3 focus:outline-none
            focus:ring-2 focus:ring-white focus:border-white transition',
            placeholder: 'Pseudo'
            }
            }) }}
            {{ form_errors(registrationForm.pseudo) }}
        </div>

        <!-- Email -->
        <div class="mb-5">
            {{ form_widget(registrationForm.email, {
            attr: {
            class: 'w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3 focus:outline-none
            focus:ring-2 focus:ring-white focus:border-white transition',
            placeholder: 'Email'
            }
            }) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        <!-- Mot de passe -->
        <div class="mb-5">
            {{ form_widget(registrationForm.plainPassword, {
            attr: {
            class: 'w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3 focus:outline-none
            focus:ring-2 focus:ring-white focus:border-white transition',
            placeholder: 'Mot de passe'
            }
            }) }}

            {# Indicateur des exigences du mot de passe #}
            <div class="mt-2 text-sm text-gray-400 bg-gray-900 p-3 rounded border border-gray-700">
                <p class="font-semibold mb-2">Votre mot de passe doit contenir :</p>
                <ul class="space-y-1">
                    <li class="flex flex-col items-start">
                        <span class="text-gray-300 mr-2">• Au moins 8 caractères</span>
                        <span class="text-gray-300 mr-2">• Au moins une lettre majuscule et une lettre minuscule</span>
                        <span class="text-gray-300 mr-2">• Au moins un caractère spécial</span>

                    </li>
                </ul>
            </div>

            {{ form_errors(registrationForm.plainPassword) }}
        </div>

        <!-- Confirmation du mot de passe -->
        <div class="mb-5">
            {{ form_widget(registrationForm.confirmPassword, {
            attr: {
            class: 'w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3 focus:outline-none
            focus:ring-2 focus:ring-white focus:border-white transition',
            placeholder: 'Confirmer le mot de passe'
            }
            }) }}
            {# Affichage de l'erreur de confirmation #}
            {% if form_errors(registrationForm.confirmPassword) %}
            <div class="text-red-400 text-sm mt-2">
                {{ form_errors(registrationForm.confirmPassword) }}
            </div>
            {% endif %}
        </div>

        <!-- Langue -->
        <div class="mb-5">
            {{ form_label(registrationForm.langue, null, {
            label_attr: { class: 'block text-gray-400 mb-2 text-lg' }
            }) }}
            {{ form_widget(registrationForm.langue, {
            attr: {
            class: 'w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3 focus:outline-none
            focus:ring-2 focus:ring-white focus:border-white transition'
            }
            }) }}
            {{ form_errors(registrationForm.langue) }}
        </div>

        <!-- Checkbox -->
        <div class="flex items-start mb-6">
            {{ form_widget(registrationForm.agreeTerms, {
            attr: {
            class: 'w-4 h-4 text-white bg-gray-800 border-gray-600 rounded focus:ring-white mt-1'
            }
            }) }}
            <div class="ml-3">
                {{ form_label(registrationForm.agreeTerms, null, {
                label_attr: { class: 'text-gray-400 text-sm' }
                }) }}
                {% if form_errors(registrationForm.agreeTerms) %}
                <div class="text-red-400 text-sm mt-1">
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Bouton -->
        <button type="submit" class="relative w-full inline-block cursor-pointer
            px-8 py-3 rounded-lg text-lg font-semibold
            text-gray-900 shadow-md overflow-hidden text-center
            bg-linear-to-tr from-[#f7f1e5] via-[#dbbe67] to-[#f5e23ad2]
            before:absolute before:inset-0
            before:bg-linear-to-tr
            before:from-[#f5e23ad2] before:via-[#dbbe67] before:to-[#f7f1e5]
            before:opacity-0
            before:transition-opacity before:duration-600 before:ease-in-out
            hover:before:opacity-100
            before:content-['']">

            <span class="relative z-10">
                S'inscrire
            </span>
        </button>

        <!-- Lien login -->
        <p class="mt-6 text-center text-gray-400 text-sm">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" class="text-white hover:underline">
                Se connecter
            </a>
        </p>

        {{ form_end(registrationForm) }}

    </div>

</main>

{% endblock %}
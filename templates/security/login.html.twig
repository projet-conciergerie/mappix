{% extends 'base.html.twig' %}

{% block title %}Connexion - Mappix{% endblock %}

{% block body %}

<main class="flex-1 flex items-center justify-center">

    <form method="post" class="w-full max-w-md my-6">

        <!-- Logo + Titre -->
        <div class="text-center mb-10 flex flex-col items-center">
            <img src="{{ asset('images/logo1.png') }}" alt="Mappix" class="w-48">
            <h1 class="text-2xl text-white font-semibold mt-6">
                Connexion
            </h1>
        </div>

        {% if error %}
        <div class="mb-6 p-4 rounded bg-red-500/20 border border-red-500 text-red-400 text-sm">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
        {% endif %}

        {% if app.user %}
        <div class="mb-6 p-4 rounded bg-blue-500/20 border border-blue-500 text-blue-300 text-sm">
            Connecté en tant que {{ app.user.userIdentifier }},
            <br>
            <a href="{{ logout_path() }}" class="underline hover:text-white">
                Se déconnecter
            </a>
        </div>
        {% endif %}

        <!-- Email -->
        <div class="mb-5">
            <label for="email" class="block text-gray-400 mb-2 text-sm">
                Adresse email
            </label>
            <input type="email" value="{{ last_username }}" name="_username" id="email" autocomplete="email" required
                autofocus class="w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3
                          focus:outline-none focus:ring-2 focus:ring-white focus:border-white transition">
        </div>

        <!-- Password -->
        <div class="mb-6">
            <label for="password" class="block text-gray-400 mb-2 text-sm">
                Mot de passe
            </label>
            <input type="password" name="_password" id="password" required class="w-full bg-gray-800 text-white border border-gray-600 rounded px-4 py-3
                          focus:outline-none focus:ring-2 focus:ring-white focus:border-white transition">
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <!-- Remember me -->
        <div class="flex items-center mb-6">
            <input type="checkbox" name="_remember_me" id="remember_me"
                class="w-4 h-4 bg-gray-800 border-gray-600 rounded focus:ring-white">
            <label for="remember_me" class="ml-3 text-gray-400 text-sm">
                Se souvenir de moi
            </label>
        </div>

        <!-- Bouton -->
        <Button class="relative w-full inline-block cursor-pointer
            px-8 py-3 rounded-lg text-lg font-semibold
            text-gray-900 shadow-md overflow-hidden text-center
            bg-linear-to-tr from-[#f7f1e5] via-[#dbbe67] to-[#f5e23ad2]
            before:absolute before:inset-0
            before:bg-linear-to-tr
            before:from-[#f5e23ad2] before:via-[#dbbe67] before:to-[#f7f1e5]
            before:opacity-0
            before:transition-opacity before:duration-600 before:ease-in-out
            hover:before:opacity-100
            before:content-['']">

            <span class="relative z-10">
                Se connecter
            </span>
        </Button>

        <p class="text-gray-400 mt-3">Si vous n'avez pas déjà de compte. <a class="hover:text-[#e6d4b6]" href="{{ path('app_register') }}">Créer un compte</a></p>

    </form>

</main>

{% endblock %}
{% extends 'tourisme_dashboard/layout.html.twig' %}

{% block content_title %}
    <h1 class="text-3xl font-bold text-gray-900 mb-6">
        Tableau de bord Office de Tourisme de Rouen
    </h1>
{% endblock %}

{% block main %}
    <div class="max-w-7xl mx-auto px-6 py-8">
        
        {# Statistiques rapides #}
        <div class="grid md:grid-cols-4 gap-6 mb-8">
            {# Widget Événements #}
            <div class="bg-gray-900 text-white rounded-lg shadow-lg p-6 hover:shadow-2xl transition">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold">Événements</h3>
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div class="text-4xl font-bold text-yellow-400 mb-2">24</div>
                <p class="text-sm text-gray-300">à venir ce mois</p>
            </div>

            {# Widget Réservations #}
            <div class="bg-gray-900 text-white rounded-lg shadow-lg p-6 hover:shadow-2xl transition">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold">Réservations</h3>
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                    </svg>
                </div>
                <div class="text-4xl font-bold text-yellow-400 mb-2">152</div>
                <p class="text-sm text-gray-300">ce mois</p>
            </div>

            {# Widget Services #}
            <div class="bg-gray-900 text-white rounded-lg shadow-lg p-6 hover:shadow-2xl transition">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold">Services</h3>
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div class="text-4xl font-bold text-yellow-400 mb-2">38</div>
                <p class="text-sm text-gray-300">actifs</p>
            </div>

            {# Widget Utilisateurs #}
            <div class="bg-gray-900 text-white rounded-lg shadow-lg p-6 hover:shadow-2xl transition">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold">Utilisateurs</h3>
                    <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </div>
                <div class="text-4xl font-bold text-yellow-400 mb-2">456</div>
                <p class="text-sm text-gray-300">inscrits</p>
            </div>
        </div>

        {# Actions rapides #}
        <div class="bg-gray-900 text-white rounded-lg shadow-lg p-6 mb-8">
            <h2 class="text-2xl font-bold mb-6">Actions rapides</h2>
            <div class="grid md:grid-cols-4 gap-4">
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\EvenementCrudController').setAction('new') }}" 
                   class="relative inline-block px-6 py-4 rounded-lg text-center font-semibold text-gray-900 shadow-md overflow-hidden bg-gradient-to-tr from-[#f7f1e5] via-[#dbbe67] to-[#f5e23ad2] hover:shadow-2xl transition-all duration-300">
                    <span class="relative z-10">Créer un événement</span>
                </a>
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ServiceCrudController').setAction('new') }}" 
                   class="relative inline-block px-6 py-4 rounded-lg text-center font-semibold text-gray-900 shadow-md overflow-hidden bg-gradient-to-tr from-[#f7f1e5] via-[#dbbe67] to-[#f5e23ad2] hover:shadow-2xl transition-all duration-300">
                    <span class="relative z-10">Créer un service</span>
                </a>
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\ReservationCrudController').setAction('index') }}" 
                   class="border border-gray-100 px-6 py-4 text-center rounded-lg hover:bg-gray-800 transition">
                    Voir les réservations
                </a>
                <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('index') }}" 
                   class="border border-gray-100 px-6 py-4 text-center rounded-lg hover:bg-gray-800 transition">
                    Gérer les utilisateurs
                </a>
            </div>
        </div>

        {# Activité récente #}
        <div class="grid md:grid-cols-2 gap-6">
            {# Derniers événements #}
            <div class="bg-gray-900 text-white rounded-lg shadow-lg overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-700">
                    <h2 class="text-xl font-bold">Derniers événements</h2>
                </div>
                <div class="p-6 space-y-4">
                    <div class="border-b border-gray-700 pb-4">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-semibold">Festival de Jazz</h3>
                            <span class="px-3 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">À venir</span>
                        </div>
                        <p class="text-sm text-gray-300">15 Mars 2024</p>
                    </div>
                    <div class="border-b border-gray-700 pb-4">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-semibold">Exposition Impressionnisme</h3>
                            <span class="px-3 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">À venir</span>
                        </div>
                        <p class="text-sm text-gray-300">22 Mars 2024</p>
                    </div>
                    <div>
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-semibold">Marché des Producteurs</h3>
                            <span class="px-3 py-1 bg-green-100 text-green-800 text-xs rounded-full">Confirmé</span>
                        </div>
                        <p class="text-sm text-gray-300">29 Mars 2024</p>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-gray-700">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\EvenementCrudController').setAction('index') }}" 
                       class="inline-block px-4 py-2 border border-white rounded-lg hover:bg-gray-800 transition text-center w-full">
                        Voir tous les événements
                    </a>
                </div>
            </div>

            {# Dernières réservations #}
            <div class="bg-gray-900 text-white rounded-lg shadow-lg overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-700">
                    <h2 class="text-xl font-bold">Dernières réservations</h2>
                </div>
                <div class="p-6 space-y-4">
                    <div class="border-b border-gray-700 pb-4">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-semibold">Visite guidée Cathédrale</h3>
                            <span class="px-3 py-1 bg-green-100 text-green-800 text-xs rounded-full">Confirmée</span>
                        </div>
                        <p class="text-sm text-gray-300">Jean Dupont - Aujourd'hui 14h</p>
                    </div>
                    <div class="border-b border-gray-700 pb-4">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-semibold">Musée des Beaux-Arts</h3>
                            <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-xs rounded-full">En attente</span>
                        </div>
                        <p class="text-sm text-gray-300">Marie Martin - Demain 10h</p>
                    </div>
                    <div>
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-semibold">Tour en bateau sur la Seine</h3>
                            <span class="px-3 py-1 bg-green-100 text-green-800 text-xs rounded-full">Confirmée</span>
                        </div>
                        <p class="text-sm text-gray-300">Pierre Durand - 20 Mars</p>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-gray-700">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ReservationCrudController').setAction('index') }}" 
                       class="inline-block px-4 py-2 border border-white rounded-lg hover:bg-gray-800 transition text-center w-full">
                        Voir toutes les réservations
                    </a>
                </div>
            </div>
        </div>

    </div>
{% endblock %}

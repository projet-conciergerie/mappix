<h2 class="text-2xl font-bold">Informations détaillées
	{{ category }}</h2>

<div
	class="flex flex-col md:flex-row gap-4 mt-4">
	<!-- Left side for thumbnail -->
	<div class="">
		{% if thumbnail %}
			<img src="{{ thumbnail }}" alt="Thumbnail" class="w-32 h-32 object-cover rounded-lg">
		{% else %}
			<div class="w-32 h-32 bg-gray-300 flex items-center justify-center rounded-lg">
				<span class="text-gray-500">No image</span>
			</div>
		{% endif %}
	</div>

	<!-- Right side for details -->
	<div class="flex-1">
		<h3 class="text-xl font-bold">{{ name?name:'Pas de Nom disponible' }}</h3>

		{% if description %}
			<p>Description :
				{{ description }}</p>
		{% endif %}

		{% if address %}
			<p>Adresse :
				{{ address }}</p>
		{% endif %}

		{% if phone %}
			<p>Téléphone :
				{{ phone }}</p>
		{% endif %}

		{% if email %}
			<p>Email :
				{{ email }}</p>
		{% endif %}

		{% if website %}
			<p>Site web :
				<a href="{{ website }}" class="text-blue-500 hover:underline" target="_blank">{{ website }}</a>
			</p>
		{% endif %}

		{% if wikipedia %}
			<p>Wikipedia :
				<a href="{{ wikipedia }}" class="text-blue-500 hover:underline" target="_blank">{{ wikipedia }}</a>
			</p>
		{% endif %}

		{% if instagram %}
			<p>Instagram :
				<a href="{{ instagram }}" class="text-blue-500 hover:underline" target="_blank">{{ instagram }}</a>
			</p>
		{% endif %}

		{% if facebook %}
			<p>Facebook :
				<a href="{{ facebook }}" class="text-blue-500 hover:underline" target="_blank">{{ facebook }}</a>
			</p>
		{% endif %}

		{% if twitter %}
			<p>Twitter :
				<a href="{{ twitter }}" class="text-blue-500 hover:underline" target="_blank">{{ twitter }}</a>
			</p>
		{% endif %}

	</div>

</div>

	<!-- Additional data -->
	{% if datas|length > 0 %}
		<div class="w-full mt-4">
			<h3 class="text-xl font-bold">Données supplémentaires</h3>
			<ul class="list-disc list-inside">
				{% for key, value in datas %}
					<li><strong>{{ key }}:</strong> {{ value }}</li>
				{% endfor %}
			</ul>
		</div>
	{% endif %}

{% extends 'base.html.twig' %}

{% block title %}MAPPIX - Conciergerie Rouen{% endblock %}

{% block body %}

<div class="w-full max-w-1920px mx-auto">

  <!-- Hero Section -->
<section class="relative h-screen flex items-center justify-center overflow-hidden">

  <!-- Image -->
  <img src="{{ asset('images/img_hero_homepage.jpg') }}"
       alt="Rouen - Conciergerie"
       class="absolute inset-0 w-full h-full object-cover">

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/40"></div>

  <!-- Contenu centré -->
  <div class="relative z-10 flex flex-col items-center text-center gap-10 px-6">

    <!-- Titre -->
    <h1 class="text-white text-5xl md:text-7xl font-bold drop-shadow-lg">
      Bienvenue sur Mappix
    </h1>

    <!-- Bloc description -->
    <div class="bg-black/50 w-full max-w-xl p-8 rounded">
      <h2 class="text-white text-base md:text-lg mb-6">
        Repérez-vous en un instant et découvrez tout ce dont
        vous avez besoin pendant votre séjour grâce à notre carte interactive.
      </h2>

      <a href="{{ path('app_register') }}"
         class="inline-block bg-white text-black px-8 py-3 text-lg font-semibold rounded shadow-lg
                hover:scale-105 hover:shadow-2xl transition duration-300">
        S'inscrire
      </a>
    </div>

  </div>
</section>
</div>

<!-- Section Evénements -->
{% if recentEvents is defined and recentEvents|length > 0 %}
<section class="py-16 text-white">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-center text-3xl font-bold mb-10">Événements à venir</h2>

    <div class="grid md:grid-cols-3 gap-8">
      {% for event in recentEvents %}
      <div class="bg-white text-black rounded shadow-lg flex flex-col p-6 hover:shadow-2xl transition">

        <h5 class="font-bold text-center mb-4">{{ event.nom }}</h5>

        <p class="grow text-sm">
          {{ event.description|length > 150 ? event.description|slice(0, 150) ~ '...' : event.description }}
        </p>

        {% if event.startAt %}
        <div class="text-gray-500 text-sm mt-3 mb-3">
          {{ event.startAt|date('d/m/Y') }}
        </div>
        {% endif %}

        <a href="#" class="mt-auto border border-black px-4 py-2 text-center rounded
                    hover:bg-black hover:text-white transition">
          En savoir plus
        </a>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-10">
      <a href="{{ path('app_evenements') }}" class="bg-white text-black px-8 py-3 rounded text-lg font-semibold
                  hover:bg-gray-200 transition">
        Voir tous les événements
      </a>
    </div>
  </div>
</section>
{% endif %}

<!-- Section Services -->
{% if services is defined and services|length > 0 %}
<section class="py-16 text-white">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-center text-3xl font-bold mb-10">Nos Services</h2>

    <div class="grid md:grid-cols-3 gap-8">
      {% for service in services %}
      <div class="bg-white text-black rounded shadow-lg flex flex-col p-6 hover:shadow-2xl transition">

        <h5 class="font-bold text-center mb-4">{{ service.nom }}</h5>

        <p class="grow text-sm">
          {{ service.description|length > 150 ? service.description|slice(0, 150) ~ '...' : service.description }}
        </p>

        <a href="#" class="mt-auto border border-black px-4 py-2 text-center rounded
                    hover:bg-black hover:text-white transition">
          Découvrir
        </a>
      </div>
      {% endfor %}
    </div>

    <div class="text-center mt-10">
      <a href="#" class="bg-white text-black px-8 py-3 rounded text-lg font-semibold
                  hover:bg-gray-200 transition">
        Voir tous les services
      </a>
    </div>
  </div>
</section>
{% endif %}
</div>

<!-- Bouton scroll top -->
<div class="fixed bottom-[20%] right-5 z-50">
  <a href="#" class="bg-white p-3 rounded-3xl shadow-lg hover:shadow-2xl transition text-black text-3xl">
    ↑
  </a>
</div>

{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}

<div class="min-h-screen flex items-center justify-center bg-[#19243b] py-12 px-6">

    <div class="bg-[#101828] w-full max-w-xl rounded-2xl shadow-2xl p-8 border border-[#E6D4B5]/20">

        <h1 class="text-3xl font-bold text-[#E6D4B5] mb-8 text-center">
            Mon Profil
        </h1>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 px-4 py-3 rounded-lg bg-green-600 text-white">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}


        <div class="mb-8 space-y-4">

            <div>
                <label class="block text-[#E6D4B5] text-sm mb-1">
                    Prénom
                </label>
                <div class="w-full px-4 py-2 rounded-lg
                            bg-[#19243b] text-[#f8f8f8]
                            border border-[#E6D4B5]/20">
                    {{ user.prenom }}
                </div>
            </div>

            <div>
                <label class="block text-[#E6D4B5] text-sm mb-1">
                    Nom
                </label>
                <div class="w-full px-4 py-2 rounded-lg
                            bg-[#19243b] text-[#f8f8f8]
                            border border-[#E6D4B5]/20">
                    {{ user.nom }}
                </div>
            </div>

        </div>
        {{ form_start(form, { attr: { class: "space-y-6" } }) }}
            <div>
                {{ form_label(form.pseudo, null, { label_attr: { class: "block text-[#f8f8f8] mb-2" } }) }}
                {{ form_widget(form.pseudo, { attr: { class: "w-full px-4 py-2 rounded-lg bg-[#19243b] text-white border border-[#E6D4B5]/30 focus:outline-none focus:ring-2 focus:ring-[#E6D4B5]" } }) }}
            </div>

            <div>
                {{ form_label(form.email, null, { label_attr: { class: "block text-[#f8f8f8] mb-2" } }) }}
                {{ form_widget(form.email, { attr: { class: "w-full px-4 py-2 rounded-lg bg-[#19243b] text-white border border-[#E6D4B5]/30 focus:outline-none focus:ring-2 focus:ring-[#E6D4B5]" } }) }}
            </div>
            <div>
                {{ form_label(form.langue, null, {
                    label_attr: { class: "block text-[#f8f8f8] mb-2" }
                }) }}

                {{ form_widget(form.langue, {
                    attr: {
                        class: "w-full px-4 py-2 rounded-lg
                                bg-[#19243b] text-white
                                border border-[#E6D4B5]/30
                                focus:outline-none
                                focus:ring-2 focus:ring-[#E6D4B5]"
                    }
                }) }}
            </div>
            <div class="flex justify-center mt-8">
                <button type="submit"
                    class="relative inline-block
                    px-8 py-3 rounded-lg text-lg font-semibold
                    text-[#101828] shadow-md overflow-hidden
                    bg-gradient-to-tr from-[#f7f1e5] via-[#dbbe67] to-[#f5e23ad2]
                    before:absolute before:inset-0
                    before:bg-gradient-to-tr
                    before:from-[#f5e23ad2] before:via-[#dbbe67] before:to-[#f7f1e5]
                    before:opacity-0
                    before:transition-opacity before:duration-500 before:ease-in-out
                    hover:before:opacity-100
                    before:content-['']
                    transition duration-200">
                    <span class="relative z-10">
                        Mettre à jour
                    </span>
                </button>
            </div>


        {{ form_end(form) }}

    </div>

</div>

{% endblock %}
